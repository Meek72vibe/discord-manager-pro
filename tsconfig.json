{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": false
  },
  "include": [
    "src/**/*",
    "dashboard/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/core/moderationService.ts",
    "src/core/aiService.ts",
    "src/core/analyticsService.ts",
    "src/core/channelService.ts",
    "src/core/constants.ts",
    "src/core/discordService.ts",
    "src/core/emojiService.ts",
    "src/core/env.ts",
    "src/core/eventService.ts",
    "src/core/roleService.ts",
    "src/core/securityService.ts",
    "src/core/summaryService.ts",
    "src/core/threadService.ts",
    "src/core/utils.ts",
    "src/core/webhookService.ts",
    "src/ai/**/*",
    "src/discord/**/*",
    "src/types/responses.ts",
    "src/types/ai-responses.ts",
    "src/utils/**/*"
  ]
}