# ─────────────────────────────────────────────────────────
# Discord Manager Pro — Environment Variables
# Copy this file to .env and fill in your values.
# OR use the dashboard: npm run setup
# ─────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────

# Discord Bot Token (discord.com/developers → Your App → Bot → Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Server ID (Discord → Settings → Advanced → Developer Mode → Right-click server → Copy ID)
DISCORD_GUILD_ID=your_guild_id_here

# ── AI PROVIDER (choose one) ──────────────────────────────

# Which AI provider to use: claude | groq | gemini | openrouter | mistral | ollama
AI_PROVIDER=groq

# Anthropic Claude (paid, best quality) — console.anthropic.com
ANTHROPIC_API_KEY=

# Groq — FREE 14,400 req/day — console.groq.com
GROQ_API_KEY=your_groq_key_here

# Google Gemini — FREE generous limits — aistudio.google.com
GEMINI_API_KEY=

# OpenRouter — FREE 30+ models — openrouter.ai
OPENROUTER_API_KEY=

# Mistral — FREE 1B tokens/month — console.mistral.ai
MISTRAL_API_KEY=

# Ollama (local, no key needed) — model name e.g. llama3.1
OLLAMA_MODEL=llama3.1

# ── OPTIONAL ──────────────────────────────────────────────

# Set to "true" to enable verbose logging
DEBUG=false

# ── SAFETY ────────────────────────────────────────────────

# SAFE_MODE (default: true)
# When true, destructive tools (ban, kick, delete_channel, bulk_delete, etc.) are disabled.
# Set to false to enable destructive tools. Use with caution.
SAFE_MODE=true
