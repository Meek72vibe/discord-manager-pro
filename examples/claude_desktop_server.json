{
    "mcpServers": {
        "sentinel": {
            "command": "node",
            "args": [
                "/absolute/path/to/sentinel/dist/src/index.js"
            ],
            "env": {
                "DISCORD_TOKEN": "your_bot_token",
                "DISCORD_GUILD_ID": "your_server_id",
                "GROQ_API_KEY": "gsk_xxxx",
                "SAFE_MODE": "true",
                "READ_ONLY": "false"
            }
        }
    }
}