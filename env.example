# Discord Manager Pro — Configuration
# Copy this file to .env and fill in your values

# ── REQUIRED ──────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id_here

# ── AI PROVIDER ───────────────────────────────────────
# Options: groq, gemini, claude, openrouter, mistral, ollama
AI_PROVIDER=groq

# Groq (FREE) — get key at console.groq.com
GROQ_API_KEY=your_groq_key_here

# Gemini (FREE) — get key at aistudio.google.com
# ANTHROPIC_API_KEY=your_gemini_key_here

# Claude (paid) — get key at console.anthropic.com
# ANTHROPIC_API_KEY=your_claude_key_here

# OpenRouter (free tier) — get key at openrouter.ai
# ANTHROPIC_API_KEY=your_openrouter_key_here

# Mistral — get key at console.mistral.ai
# MISTRAL_API_KEY=your_mistral_key_here

# ── SAFETY ────────────────────────────────────────────
# true = block all destructive actions (kick, ban, delete, etc)
SAFE_MODE=false

# ── OPTIONAL ──────────────────────────────────────────
# DEBUG=true
# OLLAMA_MODEL=llama3.1
